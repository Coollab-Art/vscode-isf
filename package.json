{
  "name": "vscode-isf",
  "publisher": "coollab",
  "displayName": "ISF (Interactive Shader Format)",
  "description": "Full IDE support for ISF shaders: JSON header validation, autocompletion, hover, GLSL diagnostics, and formatting.",
  "version": "0.1.0",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/Coollab-Art/vscode-isf"
  },
  "homepage": "https://github.com/Coollab-Art/vscode-isf",
  "bugs": {
    "url": "https://github.com/Coollab-Art/vscode-isf/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "ISF",
    "GLSL",
    "shader",
    "fragment shader",
    "Interactive Shader Format"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "isf",
        "aliases": [
          "ISF",
          "Interactive Shader Format"
        ],
        "extensions": [
          ".isf"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "isf",
        "scopeName": "source.isf",
        "path": "./syntaxes/isf.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.json": "json",
          "meta.embedded.block.glsl": "glsl"
        }
      }
    ],
    "configuration": {
      "title": "ISF",
      "properties": {
        "isf.importedImageExtensions": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "markdownDescription": "Additional file extensions to show when autocompleting `IMPORTED` image paths (e.g. `[\".ktx\", \".dds\"]`). The built-in list already covers most common image formats."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs --production",
    "compile": "tsc -p ./",
    "watch": "node esbuild.mjs --watch"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "vscode-json-languageservice": "^5.7.2"
  }
}
