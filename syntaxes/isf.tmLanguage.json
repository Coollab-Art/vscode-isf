{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ISF (Interactive Shader Format)",
  "scopeName": "source.isf",
  "patterns": [
    { "include": "#isf-header" },
    { "include": "#glsl-body" },
    { "include": "source.glsl" }
  ],
  "repository": {
    "isf-header": {
      "name": "meta.isf-header",
      "begin": "/\\*",
      "end": "\\*/",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.begin.isf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.comment.end.isf" }
      },
      "contentName": "meta.embedded.block.json",
      "patterns": [
        { "include": "source.json" }
      ]
    },
    "glsl-body": {
      "begin": "(?<=\\*/)",
      "end": "\\z",
      "contentName": "meta.embedded.block.glsl",
      "patterns": [
        { "include": "source.glsl" }
      ]
    }
  }
}
